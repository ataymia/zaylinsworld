// ─────────────────────────────────────────────────────────
//  CHARACTER CUSTOMIZATION OPTIONS
// ─────────────────────────────────────────────────────────
const SKIN_TONES  = ['#FFDBB4','#F1C27D','#C68642','#8D5524','#3b2314','#D2956A'];
const HAIR_STYLES = ['Short','Afro','Braids','Curly','Ponytail','Bald'];
const HAIR_COLORS = ['#2b1d0e','#000','#8B0000','#ffd700','#4e9eff','#ff4e91','#4eff91','#a64eff','#ff914e'];
const OUTFIT_STYLES= ['Casual','Sporty','School','Work','Fancy','Street'];
const OUTFIT_COLORS= ['#4e9eff','#ff4e4e','#4eff91','#ffd700','#a64eff','#ff914e','#fff','#333'];
const ACCESSORIES  = ['None','Sunglasses','Hat','Headphones','Mask','Crown'];

// ─────────────────────────────────────────────────────────
//  INPUT
// ─────────────────────────────────────────────────────────
document.addEventListener('keydown', e => {
  const k = e.key.toLowerCase();
  KEYS[k] = true;
  if(!STATE.running) return;
  if(k==='e') handleInteract();
  if(k==='f') handleCarEnterExit();
  if(k==='m') toggleMonsterMode();
  if(k==='c') openScreen('char-screen'), buildCharCustomizer();
  if(k==='j') openScreen('job-screen'),  buildJobScreen();
  if(k==='h') openScreen('house-screen'), buildHouseScreen();
  if(k==='escape') closeAllScreens();
});
document.addEventListener('keyup',  e => { KEYS[e.key.toLowerCase()] = false; });

// ─────────────────────────────────────────────────────────
//  TITLE / START
// ─────────────────────────────────────────────────────────
function startGame(){
  document.getElementById('title-screen').classList.add('hidden');
  buildCharCustomizer();
  openScreen('char-screen');
  STATE.running = true;
  requestAnimationFrame(gameLoop);
}

// ─────────────────────────────────────────────────────────
//  MAIN GAME LOOP
// ─────────────────────────────────────────────────────────
let lastTime = 0;
function gameLoop(ts){
  const dt = Math.min((ts - lastTime) / 16.67, 3);
  lastTime = ts;

  if(!anyScreenOpen()){
    updatePlayer(dt);
    updateNPCs(dt);
    updateNPCCars(dt);
    updateWanted(dt);
    updateShift(dt);
    updateGameTime(dt);
    checkInteractPrompt();
  }

  render();
  renderMinimap();
  updateHUD();
  requestAnimationFrame(gameLoop);
}

// ─────────────────────────────────────────────────────────
//  UPDATE PLAYER
// ─────────────────────────────────────────────────────────
function updatePlayer(dt){
  if(STATE.inCar && activeCar){
    updateDriving(dt);
    return;
  }
  let mx=0, my=0;
  if(KEYS['arrowleft']||KEYS['a'])  mx=-1;
  if(KEYS['arrowright']||KEYS['d']) mx= 1;
  if(KEYS['arrowup']||KEYS['w'])    my=-1;
  if(KEYS['arrowdown']||KEYS['s'])  my= 1;

  if(mx!==0&&my!==0){ mx*=0.707; my*=0.707; }

  const spd = STATE.monsterMode ? PLAYER.speed*2 : PLAYER.speed;
  const nx = PLAYER.x + mx*spd*dt;
  const ny = PLAYER.y + my*spd*dt;

  if(!isSolid(nx, PLAYER.y)) PLAYER.x = nx;
  if(!isSolid(PLAYER.x, ny)) PLAYER.y = ny;

  if(mx<0) PLAYER.facing='left';
  else if(mx>0) PLAYER.facing='right';
  else if(my<0) PLAYER.facing='up';
  else if(my>0) PLAYER.facing='down';

  // camera follow
  CAM.x = PLAYER.x - canvas.width/2;
  CAM.y = PLAYER.y - canvas.height/2;
}

function isSolid(wx,wy){
  const tx=Math.floor(wx/TILE), ty=Math.floor(wy/TILE);
  const t=getTile(tx,ty);
  return t===T.BUILDING||t===T.WATER;
}

// ─────────────────────────────────────────────────────────
//  DRIVING
// ─────────────────────────────────────────────────────────
function updateDriving(dt){
  if(!activeCar) return;
  const steer = (KEYS['a']||KEYS['arrowleft'] ? -1 : 0) + (KEYS['d']||KEYS['arrowright'] ? 1 : 0);
  const throttle = (KEYS['w']||KEYS['arrowup'] ? 1 : 0) - (KEYS['s']||KEYS['arrowdown'] ? 0.7 : 0);

  activeCar.speed += throttle * 0.3 * dt;
  activeCar.speed = Math.max(-activeCar.maxSpeed*0.5, Math.min(activeCar.maxSpeed, activeCar.speed));
  activeCar.speed *= 0.96;

  if(Math.abs(activeCar.speed)>0.1){
    activeCar.angle += steer * 0.04 * Math.sign(activeCar.speed) * dt;
  }

  const nx = activeCar.x + Math.sin(activeCar.angle)*activeCar.speed*dt;
  const ny = activeCar.y - Math.cos(activeCar.angle)*activeCar.speed*dt;

  if(!isSolid(nx, activeCar.y)) activeCar.x=nx;
  else { activeCar.speed *= -0.3; }
  if(!isSolid(activeCar.x, ny)) activeCar.y=ny;
  else { activeCar.speed *= -0.3; }

  PLAYER.x = activeCar.x;
  PLAYER.y = activeCar.y;
  CAM.x = PLAYER.x - canvas.width/2;
  CAM.y = PLAYER.y - canvas.height/2;

  // Speeding -> wanted
  if(Math.abs(activeCar.speed)>activeCar.maxSpeed*0.85){
    if(Math.random()<0.002) addWanted(1);
  }
}

function handleCarEnterExit(){
  if(STATE.inCar){
    STATE.inCar = false;
    PLAYER.x = activeCar.x + 40;
    PLAYER.y = activeCar.y;
    activeCar.occupied = false;
    activeCar = null;
    notify('🚗 Exited vehicle');
  } else {
    const car = nearestCar();
    if(car && dist(PLAYER, car)<80){
      if(car.isNPC && STATE.wantedLevel===0){
        // cannot steal unless monster mode
        if(!STATE.monsterMode){ notify('⚠️ That\'s not your car!'); return; }
        addWanted(2);
        notify('🚨 Grand theft auto! Wanted level up!');
      }
      activeCar = car;
      car.occupied = true;
      STATE.inCar = true;
      notify(`🚗 Entered ${car.name}`);
    } else {
      notify('No car nearby (get closer)');
    }
  }
}

function nearestCar(){
  let best=null, bd=9999;
  for(const c of allCars){
    if(!c.occupied || c===activeCar){
      const d=dist(PLAYER,c);
      if(d<bd){ bd=d; best=c; }
    }
  }
  return best;
}

// ─────────────────────────────────────────────────────────
//  NPC AI
// ─────────────────────────────────────────────────────────
function updateNPCs(dt){
  for(const n of npcs){
    n.walkTimer -= dt;
    if(n.walkTimer<=0){
      n.walkTimer = 60 + Math.random()*120;
      n.walkDuration = 30 + Math.random()*60;
      const ang = Math.random()*Math.PI*2;
      const spd = 0.5 + Math.random()*0.8;
      n.dx = Math.cos(ang)*spd;
      n.dy = Math.sin(ang)*spd;
    }
    if(n.walkDuration>0){
      n.walkDuration -= dt;
      const nx=n.x+n.dx*dt, ny=n.y+n.dy*dt;
      if(!isSolid(nx,n.y)) n.x=nx;
      if(!isSolid(n.x,ny)) n.y=ny;
      if(n.dx<0) n.facing='left';
      else if(n.dx>0) n.facing='right';
      else if(n.dy<0) n.facing='up';
      else n.facing='down';
    } else { n.dx=0; n.dy=0; }

    // flee from monster mode
    if(STATE.monsterMode){
      const d=dist(PLAYER,n);
      if(d<200){
        const ang2=Math.atan2(n.y-PLAYER.y, n.x-PLAYER.x);
        n.x += Math.cos(ang2)*2*dt;
        n.y += Math.sin(ang2)*2*dt;
      }
    }
  }
}

function updateNPCCars(dt){
  for(const c of npcCars){
    if(c.occupied) continue;
    c.aiTimer -= dt;
    if(c.aiTimer<=0){
      c.aiTimer=60+Math.random()*120;
      const ang=Math.random()*Math.PI*2;
      c.aiTarget={ dx:Math.cos(ang), dy:Math.sin(ang) };
    }
    if(c.aiTarget){
      c.angle = Math.atan2(c.aiTarget.dx, -c.aiTarget.dy);
      c.speed = 1.5+Math.random();
      const nx=c.x+Math.sin(c.angle)*c.speed*dt;
      const ny=c.y-Math.cos(c.angle)*c.speed*dt;
      if(!isSolid(nx,c.y)) c.x=nx; else c.aiTarget=null;
      if(!isSolid(c.x,ny)) c.y=ny; else c.aiTarget=null;
      // wrap
      if(c.x<0) c.x=MAP_W*TILE-10;
      if(c.x>MAP_W*TILE) c.x=10;
      if(c.y<0) c.y=MAP_H*TILE-10;
      if(c.y>MAP_H*TILE) c.y=10;
    }
  }
}

// ─────────────────────────────────────────────────────────
//  WANTED / CONSEQUENCES
// ─────────────────────────────────────────────────────────
function addWanted(n){
  STATE.wantedLevel = Math.min(5, STATE.wantedLevel+n);
  STATE.wantedTimer = 600; // ticks before cooldown
}

function updateWanted(dt){
  if(STATE.wantedLevel>0){
    STATE.wantedTimer -= dt;
    if(STATE.wantedTimer<=0){
      STATE.wantedLevel = Math.max(0, STATE.wantedLevel-1);
      STATE.wantedTimer = 400;
      if(STATE.wantedLevel===0) notify('✅ You\'re in the clear now.');
    }
    // Police chase at high levels
    if(STATE.wantedLevel>=3&&Math.random()<0.001){
      PLAYER.hp = Math.max(10, PLAYER.hp-5);
      notify('🚨 Police hit! HP -5');
    }
    if(STATE.wantedLevel>=5&&Math.random()<0.0005){
      PLAYER.money = Math.max(0, Math.floor(PLAYER.money*0.8));
      notify('💸 Busted! Fined 20% of cash.');
      STATE.wantedLevel=2;
    }
  }
}

// ─────────────────────────────────────────────────────────
//  MONSTER MODE
// ─────────────────────────────────────────────────────────
function toggleMonsterMode(){
  STATE.monsterMode = !STATE.monsterMode;
  document.getElementById('monster-badge').style.display = STATE.monsterMode?'block':'none';
  document.getElementById('monster-flash').style.opacity = STATE.monsterMode?'1':'0';
  if(STATE.monsterMode){
    notify('👹 MONSTER MODE ACTIVATED! Chaos ensues!');
    addWanted(3);
  } else {
    notify('😇 Calmed down. Monster mode off.');
    document.getElementById('monster-flash').style.opacity='0';
  }
}

// ─────────────────────────────────────────────────────────
//  WORK SHIFT
// ─────────────────────────────────────────────────────────
function updateShift(dt){
  if(!PLAYER.shiftActive||!PLAYER.job) return;
  const job = JOBS.find(j=>j.id===PLAYER.job);
  if(!job) return;
  PLAYER.shiftProgress += dt;
  if(PLAYER.shiftProgress >= job.duration*60){
    PLAYER.shiftActive=false;
    PLAYER.shiftProgress=0;
    PLAYER.money += job.pay;
    PLAYER.energy = Math.max(0, PLAYER.energy-15);
    notify(`💰 Shift complete! +$${job.pay} earned.`);
    document.getElementById('hud-shift').textContent='';
  } else {
    const pct = Math.round(PLAYER.shiftProgress/(job.duration*60)*100);
    document.getElementById('hud-shift').textContent=`Shift: ${pct}%`;
  }
}

// ─────────────────────────────────────────────────────────
//  GAME TIME
// ─────────────────────────────────────────────────────────
function updateGameTime(dt){
  STATE.gameTime += dt*0.05;
  if(STATE.gameTime >= 24*60){
    STATE.gameTime=0;
    STATE.day++;
    PLAYER.energy = Math.min(100, PLAYER.energy+40);
    PLAYER.hp     = Math.min(100, PLAYER.hp+10);
    notify(`🌅 Day ${STATE.day} begins!`);
    // Rent
    if(PLAYER.house){
      const h=HOUSES.find(x=>x.id===PLAYER.house);
      if(h&&h.rent>0){
        PLAYER.money=Math.max(0,PLAYER.money-h.rent);
        notify(`🏠 Rent paid: $${h.rent}`);
      }
    }
  }
  const h=Math.floor(STATE.gameTime/60), m=Math.floor(STATE.gameTime%60);
  document.getElementById('hud-time').textContent=`Day ${STATE.day} · ${h}:${m<10?'0'+m:m}`;
}

// ─────────────────────────────────────────────────────────
//  INTERACT
// ─────────────────────────────────────────────────────────
function handleInteract(){
  // NPC?
  for(const n of npcs){
    if(dist(PLAYER,n)<60){
      talkToNPC(n);
      return;
    }
  }
  // Zone?
  const z=getZone(PLAYER.x, PLAYER.y);
  if(z){
    if(z.name.includes('Frostbox')) openShop('frostbox');
    else if(z.name.includes('Block Supply')) openShop('blocksupply');
    else if(z.name.includes('School')) { openScreen('school-screen'); buildSchoolScreen(); }
    else if(z.name.includes('Hospital')){ PLAYER.hp=100; PLAYER.energy=Math.min(100,PLAYER.energy+30); notify('🏥 Healed! HP restored.'); }
    else if(z.name.includes('Police')&&STATE.wantedLevel>0){ STATE.wantedLevel=0; PLAYER.money=Math.max(0,PLAYER.money-100); notify('👮 Turned yourself in. -$100 fine, record cleared.'); }
    else if(z.name.includes('Bank')){ notify(`🏦 Balance: $${PLAYER.money}`); }
    else notify(`📍 You are at: ${z.name}`);
  } else {
    notify('Nothing nearby to interact with');
  }
}

function checkInteractPrompt(){
  const ip=document.getElementById('interact-prompt');
  let msg='';
  for(const n of npcs){
    if(dist(PLAYER,n)<70){ msg=`[E] Talk to ${n.name}`; break; }
  }
  if(!msg){
    const z=getZone(PLAYER.x,PLAYER.y);
    if(z) msg=`[E] Enter ${z.name}`;
  }
  if(!msg && !STATE.inCar){
    const c=nearestCar();
    if(c&&dist(PLAYER,c)<80) msg=`[F] ${c.isNPC?'(Illegal!)':''} Enter ${c.name}`;
  }
  if(msg){ ip.textContent=msg; ip.style.opacity='1'; }
  else    { ip.style.opacity='0'; }
}

// ─────────────────────────────────────────────────────────
//  NPC DIALOG (with memory)
// ─────────────────────────────────────────────────────────
function talkToNPC(n){
  if(!PLAYER.npcMemory[n.id]) PLAYER.npcMemory[n.id]={attitude:50,visits:0,lastTopic:null};
  const mem=PLAYER.npcMemory[n.id];
  mem.visits++;

  const greets = [
    `Hey ${PLAYER.name}! Good to see you.`,
    `What's up? You're back again — visit #${mem.visits}!`,
    `Oh it's you again. You've talked to me ${mem.visits} times!`,
    `${mem.attitude>60?'I like you!':'Hmm, you seem suspicious...'}`,
  ];
  const dialog = greets[Math.min(mem.visits-1, greets.length-1)];

  document.getElementById('npc-name-title').textContent=`${n.name} (${n.role})`;
  document.getElementById('npc-dialog-text').textContent=dialog;

  const opts=document.getElementById('npc-options');
  opts.innerHTML='';
  const options=[
    { label:'👋 Greet', fn:()=>{ mem.attitude=Math.min(100,mem.attitude+5); notify(`${n.name} likes you more (+5 attitude)`); closeScreen('npc-screen'); }},
    { label:'🎁 Gift ($20)', fn:()=>{
      if(PLAYER.money<20){ notify('Not enough cash'); return; }
      PLAYER.money-=20; mem.attitude=Math.min(100,mem.attitude+15);
      notify(`${n.name} loves the gift! +15 attitude`); closeScreen('npc-screen');
    }},
    { label:'😠 Taunt', fn:()=>{ mem.attitude=Math.max(0,mem.attitude-15); addWanted(mem.attitude<20?1:0); notify(`${n.name} is upset!`); closeScreen('npc-screen'); }},
    { label:'❓ Ask about job', fn:()=>{
      document.getElementById('npc-dialog-text').textContent=
        n.role==='Teacher'?`Come study at Zaylin High! Education helps you get better jobs.`:
        n.role==='Police'?`Keep the city clean. Turn yourself in at Police HQ if wanted.`:
        `I work at the ${n.role} station. You should check the job board!`;
    }},
    { label:'🚪 Bye', fn:()=>closeScreen('npc-screen') },
  ];
  for(const o of options){
    const b=document.createElement('button');
    b.className='btn btn-sm'; b.textContent=o.label;
    b.onclick=o.fn; opts.appendChild(b);
  }
  openScreen('npc-screen');
}

// ─────────────────────────────────────────────────────────
//  SHOPS
// ─────────────────────────────────────────────────────────
function openShop(type){
  document.getElementById('shop-title').textContent =
    type==='frostbox'?'💎 Frostbox Jewelry':'🛍️ Block Supply';
  const tabs=document.getElementById('shop-tabs');
  const content=document.getElementById('shop-content');
  tabs.innerHTML=''; content.innerHTML='';

  const sections = type==='frostbox'
    ? [{key:'necklaces',label:'📿 Necklaces'},{key:'rings',label:'💍 Rings'},{key:'earrings',label:'✨ Earrings'}]
    : [{key:'caps',label:'🧢 Caps'},{key:'backpacks',label:'🎒 Backpacks'},{key:'shoes',label:'👟 Shoes'}];

  function showTab(key){
    tabs.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
    tabs.querySelector(`[data-key="${key}"]`).classList.add('active');
    content.innerHTML='';
    const items = type==='frostbox'?JEWELRY[key]:GEAR[key];
    const equip  = type==='frostbox'?PLAYER.jewelry:PLAYER.gear;
    const slot   = type==='frostbox'?key.slice(0,-1):key.slice(0,-1); // remove 's' — rough pluralization
    for(const item of items){
      let owned=false;
      if(type==='frostbox'){
        if(key==='rings') owned=equip.rings.includes(item.id);
        else owned=equip[slot]===item.id;
      } else {
        owned=equip[key.slice(0,-1)]===item.id;
      }
      const d=document.createElement('div');
      d.className=`option-card${owned?' selected':''}`;
      d.innerHTML=`<div class="card-icon">${item.icon}</div>
        <div class="card-label">${item.name}</div>
        <div style="color:#4eff91;font-weight:700;font-size:13px">$${item.cost}</div>
        ${owned?'<div style="color:#4eff91;font-size:11px">✓ Equipped</div>':''}`;
      d.onclick=()=>{
        if(owned){ notify(`Already wearing ${item.name}`); return; }
        if(PLAYER.money<item.cost){ notify('Not enough cash!'); return; }
        PLAYER.money-=item.cost;
        if(type==='frostbox'){
          if(key==='rings') PLAYER.jewelry.rings.push(item.id);
          else PLAYER.jewelry[slot]=item.id;
        } else {
          PLAYER.gear[key.slice(0,-1)]=item.id;
        }
        notify(`✨ Got ${item.name}!`);
        showTab(key);
      };
      content.appendChild(d);
    }
    content.style.display='grid';
    content.style.gridTemplateColumns='1fr 1fr 1fr';
    content.style.gap='10px';
  }

  for(const s of sections){
    const t=document.createElement('div');
    t.className='tab'; t.textContent=s.label; t.dataset.key=s.key;
    t.onclick=()=>showTab(s.key);
    tabs.appendChild(t);
  }
  showTab(sections[0].key);
  openScreen('shop-screen');
}

// ─────────────────────────────────────────────────────────
//  JOB SCREEN
// ─────────────────────────────────────────────────────────
function buildJobScreen(){
  const c=document.getElementById('job-content');
  c.innerHTML='';
  for(const j of JOBS){
    const meetsReq = Object.entries(j.req).every(([k,v])=>PLAYER[k]>=v);
    const isActive = PLAYER.job===j.id;
    const d=document.createElement('div');
    d.className='option-card'; d.style.display='flex'; d.style.flexDirection='column'; d.style.gap='6px';
    d.innerHTML=`
      <div style="font-size:17px;font-weight:700">${j.name}</div>
      <div style="font-size:12px;color:#aaa">${j.desc}</div>
      <div style="font-size:13px;color:#4eff91">$${j.pay} per shift · ${j.duration}min</div>
      ${!meetsReq?`<div style="font-size:11px;color:#ff4e6a">🔒 Requires: ${Object.entries(j.req).map(([k,v])=>`${k} ${v}+`).join(', ')}</div>`:''}
    `;
    if(meetsReq){
      const b=document.createElement('button');
      if(isActive&&PLAYER.shiftActive){ b.className='btn btn-sm'; b.textContent='⏳ On shift...'; b.disabled=true; }
      else if(isActive){ b.className='btn btn-sm btn-blue'; b.textContent='⚡ Start Shift';
        b.onclick=()=>{ PLAYER.shiftActive=true; PLAYER.shiftProgress=0; notify(`⚡ Shift started at ${j.name}!`); closeScreen('job-screen'); };
      } else {
        b.className='btn btn-sm'; b.textContent='Apply';
        b.onclick=()=>{ PLAYER.job=j.id; PLAYER.shiftActive=false; PLAYER.shiftProgress=0;
          document.getElementById('hud-job').textContent=j.name;
          notify(`💼 You are now a ${j.name}!`); buildJobScreen(); };
      }
      d.appendChild(b);
    }
    c.appendChild(d);
  }
}

// ─────────────────────────────────────────────────────────
//  HOUSE SCREEN
// ─────────────────────────────────────────────────────────
function buildHouseScreen(){
  const c=document.getElementById('house-content');
  c.innerHTML='';
  for(const h of HOUSES){
    const owned=PLAYER.house===h.id;
    const d=document.createElement('div');
    d.className=`option-card${owned?' selected':''}`;
    d.innerHTML=`
      <div style="font-size:22px">${h.name.split(' ')[0]}</div>
      <div style="font-weight:700">${h.name}</div>
      <div style="font-size:12px;color:#aaa;margin:4px 0">${h.desc}</div>
      <div style="color:#4eff91;font-weight:700">$${h.cost}</div>
      ${owned?'<div style="color:#4eff91">✓ Home</div>':''}
    `;
    if(!owned){
      const b=document.createElement('button');
      b.className='btn btn-sm'; b.textContent=`Buy $${h.cost}`;
      b.onclick=()=>{
        if(PLAYER.money<h.cost){ notify('Not enough cash!'); return; }
        PLAYER.money-=h.cost;
        PLAYER.house=h.id;
        notify(`🏠 Moved into ${h.name}!`);
        PLAYER.mood=Math.min(100,PLAYER.mood+20);
        buildHouseScreen();
      };
      d.appendChild(b);
    }
    c.appendChild(d);
  }
}

// ─────────────────────────────────────────────────────────
//  SCHOOL SCREEN
// ─────────────────────────────────────────────────────────
function buildSchoolScreen(){
  const c=document.getElementById('school-content');
  c.innerHTML=`<p style="color:#aaa;font-size:13px;margin-bottom:14px">Improve your stats to unlock better jobs and opportunities.</p>`;
  for(const course of COURSES){
    const d=document.createElement('div');
    d.className='option-card'; d.style.display='flex'; d.style.alignItems='center'; d.style.gap='12px';
    d.innerHTML=`
      <div style="font-size:26px">${course.name.split(' ')[0]}</div>
      <div style="flex:1">
        <div style="font-weight:700">${course.name}</div>
        <div style="font-size:12px;color:#aaa">+${course.gain} ${course.stat} · ${course.time}min · $${course.cost}</div>
      </div>
    `;
    const b=document.createElement('button');
    b.className='btn btn-sm'; b.textContent='Attend';
    b.onclick=()=>{
      if(PLAYER.money<course.cost){ notify('Not enough cash!'); return; }
      PLAYER.money-=course.cost;
      PLAYER[course.stat]=Math.min(100,(PLAYER[course.stat]||0)+course.gain);
      notify(`📚 Completed ${course.name}! +${course.gain} ${course.stat}`);
      buildSchoolScreen();
    };
    d.appendChild(b);
    c.appendChild(d);
  }
}

// ─────────────────────────────────────────────────────────
//  CHARACTER CUSTOMIZER BUILDER
// ─────────────────────────────────────────────────────────
function buildCharCustomizer(){
  // Skin
  const ss=document.getElementById('skin-swatches');
  if(ss) ss.innerHTML='';
  SKIN_TONES.forEach((c,i)=>{
    const s=document.createElement('span');
    s.className=`color-swatch${PLAYER.skinTone===c?' selected':''}`;
    s.style.background=c;
    s.onclick=()=>{ PLAYER.skinTone=c; buildCharCustomizer(); };
    if(ss) ss.appendChild(s);
  });
  // Hair styles
  const hs=document.getElementById('hair-styles');
  if(hs) hs.innerHTML='';
  HAIR_STYLES.forEach((h,i)=>{
    const d=document.createElement('div');
    d.className=`option-card${PLAYER.hairStyle===i?' selected':''}`;
    d.innerHTML=`<div class="card-label">${h}</div>`;
    d.onclick=()=>{ PLAYER.hairStyle=i; buildCharCustomizer(); };
    if(hs) hs.appendChild(d);
  });
  // Hair colors
  const hc=document.getElementById('hair-colors');
  if(hc) hc.innerHTML='';
  HAIR_COLORS.forEach(c=>{
    const s=document.createElement('span');
    s.className=`color-swatch${PLAYER.hairColor===c?' selected':''}`;
    s.style.background=c;
    s.onclick=()=>{ PLAYER.hairColor=c; buildCharCustomizer(); };
    if(hc) hc.appendChild(s);
  });
  // Outfits
  const os=document.getElementById('outfit-styles');
  if(os) os.innerHTML='';
  OUTFIT_STYLES.forEach((o,i)=>{
    const d=document.createElement('div');
    d.className=`option-card${PLAYER.outfitStyle===i?' selected':''}`;
    d.innerHTML=`<div class="card-label">${o}</div>`;
    d.onclick=()=>{ PLAYER.outfitStyle=i; buildCharCustomizer(); };
    if(os) os.appendChild(d);
  });
  // Outfit colors
  const oc=document.getElementById('outfit-colors');
  if(oc) oc.innerHTML='';
  OUTFIT_COLORS.forEach(c=>{
    const s=document.createElement('span');
    s.className=`color-swatch${PLAYER.outfitColor===c?' selected':''}`;
    s.style.background=c;
    s.onclick=()=>{ PLAYER.outfitColor=c; buildCharCustomizer(); };
    if(oc) oc.appendChild(s);
  });
  // Accessories
  const ac=document.getElementById('accessories');
  if(ac) ac.innerHTML='';
  ACCESSORIES.forEach((a,i)=>{
    const d=document.createElement('div');
    d.className=`option-card${PLAYER.accessory===i?' selected':''}`;
    d.innerHTML=`<div class="card-label">${a}</div>`;
    d.onclick=()=>{ PLAYER.accessory=i; buildCharCustomizer(); };
    if(ac) ac.appendChild(d);
  });
  drawCharPreview();
}

function saveCharacter(){
  const inp=document.getElementById('player-name-input');
  if(inp) PLAYER.name=inp.value||'Zaylin';
  closeScreen('char-screen');
  notify(`✅ Look saved! Looking good, ${PLAYER.name}!`);
}

// ─────────────────────────────────────────────────────────
//  CHARACTER PREVIEW CANVAS
// ─────────────────────────────────────────────────────────
function drawCharPreview(){
  const pv=document.getElementById('char-preview');
  if(!pv) return;
  const pc=pv.getContext('2d');
  pc.clearRect(0,0,100,140);
  drawPersonDetailed(pc, 50, 70, PLAYER, 2.2, false);
}

// ─────────────────────────────────────────────────────────
//  RENDERING
// ─────────────────────────────────────────────────────────
function render(){
  ctx.fillStyle='#1a1a1a';
  ctx.fillRect(0,0,canvas.width,canvas.height);

  ctx.save();
  ctx.translate(-Math.round(CAM.x), -Math.round(CAM.y));

  // Tiles
  const startX=Math.max(0,Math.floor(CAM.x/TILE));
  const endX  =Math.min(MAP_W-1,Math.ceil((CAM.x+canvas.width)/TILE));
  const startY=Math.max(0,Math.floor(CAM.y/TILE));
  const endY  =Math.min(MAP_H-1,Math.ceil((CAM.y+canvas.height)/TILE));

  for(let tx=startX;tx<=endX;tx++){
    for(let ty=startY;ty<=endY;ty++){
      const t=getTile(tx,ty);
      ctx.fillStyle=TILE_COLORS[t]||'#333';
      ctx.fillRect(tx*TILE, ty*TILE, TILE, TILE);
      // Road markings
      if(t===T.ROAD){
        ctx.fillStyle='rgba(255,255,100,0.15)';
        if(tx%12===6) ctx.fillRect(tx*TILE+14,ty*TILE,4,TILE);
        if(ty%12===6) ctx.fillRect(tx*TILE,ty*TILE+14,TILE,4);
      }
      // Building details
      if(t===T.BUILDING||t===T.SHOP||t===T.SCHOOL||t===T.POLICE||t===T.HOSPITAL||t===T.BANK){
        ctx.fillStyle='rgba(0,0,0,.3)';
        ctx.fillRect(tx*TILE+2,ty*TILE+2,TILE-4,TILE-4);
        // windows
        ctx.fillStyle='rgba(255,255,150,0.5)';
        for(let wx=0;wx<3;wx++) for(let wy=0;wy<4;wy++){
          ctx.fillRect(tx*TILE+5+wx*9, ty*TILE+4+wy*7, 5,4);
        }
      }
      // Park trees
      if(t===T.PARK&&(tx+ty)%3===0){
        ctx.fillStyle='#2a6b30';
        ctx.beginPath();
        ctx.arc(tx*TILE+16,ty*TILE+16,10,0,Math.PI*2);
        ctx.fill();
      }
    }
  }

  // Zone labels
  for(const z of ZONES){
    if(z.x>CAM.x-200&&z.x<CAM.x+canvas.width+200&&z.y>CAM.y-200&&z.y<CAM.y+canvas.height+200){
      ctx.save();
      ctx.globalAlpha=0.55;
      ctx.fillStyle=z.color;
      ctx.beginPath();
      ctx.arc(z.x,z.y,z.r,0,Math.PI*2);
      ctx.fill();
      ctx.globalAlpha=1;
      ctx.fillStyle='#fff';
      ctx.font='bold 12px Segoe UI';
      ctx.textAlign='center';
      ctx.fillText(z.name,z.x,z.y);
      ctx.restore();
    }
  }

  // NPC Cars
  for(const c of allCars) drawCar(ctx, c);

  // NPCs
  for(const n of npcs) drawPersonDetailed(ctx, n.x, n.y, n, 1, false);

  // Player
  if(!STATE.inCar){
    drawPersonDetailed(ctx, PLAYER.x, PLAYER.y, PLAYER, 1, true);
    // player name
    ctx.fillStyle='#fff';
    ctx.font='bold 11px Segoe UI';
    ctx.textAlign='center';
    ctx.fillText(PLAYER.name, PLAYER.x, PLAYER.y - 22);
  }

  // Monster mode aura
  if(STATE.monsterMode){
    ctx.save();
    const grad=ctx.createRadialGradient(PLAYER.x,PLAYER.y,0,PLAYER.x,PLAYER.y,120);
    grad.addColorStop(0,'rgba(255,0,60,0.35)');
    grad.addColorStop(1,'rgba(255,0,60,0)');
    ctx.fillStyle=grad;
    ctx.beginPath(); ctx.arc(PLAYER.x,PLAYER.y,120,0,Math.PI*2); ctx.fill();
    ctx.restore();
  }

  ctx.restore();
}

// ─────────────────────────────────────────────────────────
//  DRAW CHARACTER
// ─────────────────────────────────────────────────────────
function drawPersonDetailed(c, x, y, p, scale=1, isPlayer=false){
  const s=scale;
  c.save();
  c.translate(x, y);

  // Shadow
  c.fillStyle='rgba(0,0,0,0.25)';
  c.beginPath();
  c.ellipse(0, 14*s, 12*s, 5*s, 0, 0, Math.PI*2);
  c.fill();

  const skin = p.skinTone || p.skin || '#C68642';
  const outfit = p.outfitColor || p.color || '#4e9eff';
  const hair   = p.hairColor   || '#2b1d0e';
  const hairSt = p.hairStyle   || 0;

  // Body / outfit
  c.fillStyle = outfit;
  c.beginPath();
  c.roundRect(-7*s, -4*s, 14*s, 16*s, 3*s);
  c.fill();

  // Arms
  c.fillStyle = skin;
  c.fillRect(-12*s, -3*s, 5*s, 10*s);
  c.fillRect(7*s,   -3*s, 5*s, 10*s);

  // Legs
  c.fillStyle='#333';
  c.fillRect(-6*s, 12*s, 5*s, 9*s);
  c.fillRect(1*s,  12*s, 5*s, 9*s);

  // Shoes (Block Supply)
  const shoeC = p.gear?.shoes ? '#4eff91' : '#fff';
  c.fillStyle=shoeC;
  c.fillRect(-7*s, 20*s, 6*s, 3*s);
  c.fillRect(1*s,  20*s, 6*s, 3*s);

  // Head
  c.fillStyle = skin;
  c.beginPath();
  c.arc(0, -10*s, 9*s, 0, Math.PI*2);
  c.fill();

  // Face
  c.fillStyle='rgba(0,0,0,0.7)';
  c.fillRect(-3*s, -12*s, 2.5*s, 2*s); // left eye
  c.fillRect(0.5*s,-12*s, 2.5*s, 2*s); // right eye
  c.fillStyle='rgba(0,0,0,0.5)';
  c.fillRect(-2*s, -9*s, 4*s, 1.5*s);  // mouth

  // Hair
  c.fillStyle=hair;
  if(hairSt===0){ // Short
    c.beginPath(); c.arc(0,-10*s,9*s,Math.PI,0); c.fill();
  } else if(hairSt===1){ // Afro
    c.beginPath(); c.arc(0,-11*s,13*s,0,Math.PI*2); c.fill();
    c.fillStyle=skin; c.beginPath(); c.arc(0,-10*s,9*s,0,Math.PI*2); c.fill();
    c.fillStyle=skin; c.fillRect(-7*s,-11*s,14*s,4*s);
  } else if(hairSt===2){ // Braids
    c.beginPath(); c.arc(0,-10*s,9*s,Math.PI,0); c.fill();
    c.fillRect(-2*s,-1*s,4*s,12*s);
  } else if(hairSt===3){ // Curly
    for(let i=0;i<6;i++){
      const a=i/6*Math.PI;
      c.beginPath(); c.arc(Math.cos(a)*10*s,-10*s+Math.sin(a)*5*s-5*s,5*s,0,Math.PI*2); c.fill();
    }
  } else if(hairSt===4){ // Ponytail
    c.beginPath(); c.arc(0,-10*s,9*s,Math.PI,0); c.fill();
    c.fillRect(-2*s,-20*s,4*s,12*s);
  }
  // Bald = no hair drawn

  // Jewelry (Frostbox necklace glow)
  if(isPlayer && p.jewelry?.necklace){
    const jItems=[...JEWELRY.necklaces,...JEWELRY.rings,...JEWELRY.earrings];
    const jItem=jItems.find(j=>j.id===p.jewelry.necklace);
    if(jItem){
      c.fillStyle=jItem.color;
      c.globalAlpha=0.8;
      c.beginPath(); c.arc(0, 2*s, 3*s, 0, Math.PI*2); c.fill();
      c.globalAlpha=1;
    }
  }

  // Accessory
  if(isPlayer){
    const acc=p.accessory||0;
    if(acc===1){ // Sunglasses
      c.fillStyle='rgba(0,0,0,0.8)';
      c.fillRect(-7*s,-13*s,6*s,3*s);
      c.fillRect(1*s,-13*s,6*s,3*s);
      c.fillStyle='#555';
      c.fillRect(-1.5*s,-12.5*s,3*s,1.5*s);
    } else if(acc===2){ // Hat
      c.fillStyle='#333';
      c.fillRect(-10*s,-18*s,20*s,4*s);
      c.fillRect(-6*s,-24*s,12*s,8*s);
    } else if(acc===3){ // Headphones
      c.strokeStyle='#555'; c.lineWidth=2*s;
      c.beginPath(); c.arc(0,-10*s,12*s,Math.PI*1.1,Math.PI*1.9); c.stroke();
      c.fillStyle='#333';
      c.fillRect(-12.5*s,-12*s,4*s,5*s);
      c.fillRect(8.5*s,-12*s,4*s,5*s);
    } else if(acc===4){ // Mask
      c.fillStyle='#222'; c.globalAlpha=0.85;
      c.beginPath(); c.roundRect(-6*s,-11*s,12*s,6*s,2*s); c.fill();
      c.globalAlpha=1;
    } else if(acc===5){ // Crown
      c.fillStyle='#ffd700';
      c.beginPath();
      c.moveTo(-7*s,-19*s); c.lineTo(-7*s,-24*s);
      c.lineTo(-3.5*s,-22*s); c.lineTo(0,-26*s);
      c.lineTo(3.5*s,-22*s); c.lineTo(7*s,-24*s);
      c.lineTo(7*s,-19*s); c.closePath();
      c.fill();
    }
    // Block Supply backpack
    if(p.gear?.backpack){
      c.fillStyle='#ff914e'; c.globalAlpha=0.9;
      c.beginPath(); c.roundRect(8*s,-5*s,7*s,12*s,2*s); c.fill();
      c.globalAlpha=1;
    }
    // Block Supply cap
    if(p.gear?.cap){
      c.fillStyle='#4eff91';
      c.fillRect(-9*s,-19*s,18*s,4*s);
      c.fillRect(-5*s,-25*s,10*s,7*s);
    }
  }

  c.restore();
}

// ─────────────────────────────────────────────────────────
//  DRAW CAR
// ─────────────────────────────────────────────────────────
function drawCar(c, car){
  c.save();
  c.translate(car.x, car.y);
  c.rotate(car.angle);
  // Body
  c.fillStyle=car.color;
  c.beginPath();
  c.roundRect(-car.w/2, -car.h/2, car.w, car.h, 5);
  c.fill();
  // Windshield
  c.fillStyle='rgba(120,200,255,0.5)';
  c.fillRect(-car.w/2+3, -car.h/2+4, car.w-6, car.h/3);
  // Headlights
  c.fillStyle='#ffffaa';
  c.fillRect(-car.w/2+2,-car.h/2+2,6,4);
  c.fillRect(car.w/2-8,-car.h/2+2,6,4);
  // Taillights
  c.fillStyle='#ff4444';
  c.fillRect(-car.w/2+2,car.h/2-6,6,4);
  c.fillRect(car.w/2-8,car.h/2-6,6,4);
  c.restore();
}

// ─────────────────────────────────────────────────────────
//  MINIMAP
// ─────────────────────────────────────────────────────────
function renderMinimap(){
  mmCtx.fillStyle='#111';
  mmCtx.fillRect(0,0,160,160);
  const scale=160/(MAP_W*TILE);
  // Tiles
  for(let tx=0;tx<MAP_W;tx+=2){
    for(let ty=0;ty<MAP_H;ty+=2){
      const t=getTile(tx,ty);
      mmCtx.fillStyle=TILE_COLORS[t]||'#333';
      mmCtx.fillRect(tx*TILE*scale,ty*TILE*scale,TILE*scale*2,TILE*scale*2);
    }
  }
  // Player
  mmCtx.fillStyle='#4eff91';
  mmCtx.beginPath();
  mmCtx.arc(PLAYER.x*scale, PLAYER.y*scale, 4, 0, Math.PI*2);
  mmCtx.fill();
  // NPCs
  for(const n of npcs){
    mmCtx.fillStyle='#fff';
    mmCtx.fillRect(n.x*scale-1.5,n.y*scale-1.5,3,3);
  }
  // NPC cars
  mmCtx.fillStyle='#ff4e4e';
  for(const c of npcCars){
    mmCtx.fillRect(c.x*scale-2,c.y*scale-2,4,4);
  }
  // View rect
  mmCtx.strokeStyle='rgba(255,255,255,.3)';
  mmCtx.strokeRect(CAM.x*scale,CAM.y*scale,canvas.width*scale,canvas.height*scale);
}

// ─────────────────────────────────────────────────────────
//  HUD UPDATE
// ─────────────────────────────────────────────────────────
function updateHUD(){
  document.getElementById('bar-hp').style.width     =clamp(PLAYER.hp,0,100)+'%';
  document.getElementById('bar-energy').style.width =clamp(PLAYER.energy,0,100)+'%';
  document.getElementById('bar-mood').style.width   =clamp(PLAYER.mood,0,100)+'%';
  document.getElementById('bar-edu').style.width    =clamp(PLAYER.education,0,100)+'%';
  document.getElementById('bar-str').style.width    =clamp(PLAYER.strength,0,100)+'%';
  document.getElementById('money-display').textContent='$'+PLAYER.money;
  const stars='★'.repeat(STATE.wantedLevel)+'☆'.repeat(5-STATE.wantedLevel);
  document.getElementById('wanted-stars').textContent=stars;
  document.getElementById('wanted-stars').style.color=STATE.wantedLevel>2?'#ff4e6a':STATE.wantedLevel>0?'#ffd700':'#888';
  // Job
  if(PLAYER.job){
    const j=JOBS.find(x=>x.id===PLAYER.job);
    document.getElementById('hud-job').textContent=j?j.name:'Unemployed';
  }
  // Location
  const z=getZone(PLAYER.x,PLAYER.y);
  document.getElementById('hud-location').textContent=z?z.name:STATE.inCar?`Driving ${activeCar?.name||''}`:PLAYER.house?'At Home':'Zaylin City';
}

// ─────────────────────────────────────────────────────────
//  NOTIFICATIONS
// ─────────────────────────────────────────────────────────
let notifTimeout=null;
function notify(msg){
  const el=document.getElementById('notif');
  el.textContent=msg; el.style.opacity='1';
  if(notifTimeout) clearTimeout(notifTimeout);
  notifTimeout=setTimeout(()=>{ el.style.opacity='0'; },2800);
}

// ─────────────────────────────────────────────────────────
//  SCREEN MANAGEMENT
// ─────────────────────────────────────────────────────────
function openScreen(id){ document.getElementById(id).classList.remove('hidden'); }
function closeScreen(id){ document.getElementById(id).classList.add('hidden'); }
function closeAllScreens(){
  ['char-screen','shop-screen','house-screen','job-screen','school-screen','npc-screen']
    .forEach(s=>closeScreen(s));
}
function anyScreenOpen(){
  return ['char-screen','shop-screen','house-screen','job-screen','school-screen','npc-screen']
    .some(s=>!document.getElementById(s).classList.contains('hidden'));
}

// ─────────────────────────────────────────────────────────
//  UTILS
// ─────────────────────────────────────────────────────────
function dist(a,b){ const dx=a.x-b.x,dy=a.y-b.y; return Math.sqrt(dx*dx+dy*dy); }
function clamp(v,mn,mx){ return Math.max(mn,Math.min(mx,v)); }

// CanvasRenderingContext2D.roundRect polyfill for older browsers
if(!CanvasRenderingContext2D.prototype.roundRect){
  CanvasRenderingContext2D.prototype.roundRect=function(x,y,w,h,r){
    r=Math.min(r,w/2,h/2);
    this.beginPath();
    this.moveTo(x+r,y);
    this.lineTo(x+w-r,y);
    this.quadraticCurveTo(x+w,y,x+w,y+r);
    this.lineTo(x+w,y+h-r);
    this.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
    this.lineTo(x+r,y+h);
    this.quadraticCurveTo(x,y+h,x,y+h-r);
    this.lineTo(x,y+r);
    this.quadraticCurveTo(x,y,x+r,y);
    this.closePath();
  };
}
</script>
</body>
</html>
