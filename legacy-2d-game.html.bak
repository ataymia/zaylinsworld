<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Zaylin's World</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: #111; overflow: hidden; font-family: 'Segoe UI', Arial, sans-serif; }
  canvas { display: block; }

  /* ── HUD ── */
  #hud {
    position: fixed; top: 0; left: 0; right: 0;
    display: flex; justify-content: space-between; align-items: flex-start;
    padding: 10px 16px; pointer-events: none; z-index: 50;
  }
  .hud-box {
    background: rgba(0,0,0,.65); border: 1px solid rgba(255,255,255,.15);
    border-radius: 10px; padding: 8px 12px; color: #fff; font-size: 13px;
    backdrop-filter: blur(4px); pointer-events: all;
  }
  .hud-box h3 { font-size: 11px; color: #aaa; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
  #stat-bars { display: flex; flex-direction: column; gap: 4px; min-width: 160px; }
  .sbar { display: flex; align-items: center; gap: 6px; font-size: 12px; }
  .sbar-track { flex: 1; height: 7px; background: #333; border-radius: 4px; overflow: hidden; }
  .sbar-fill { height: 100%; border-radius: 4px; transition: width .3s; }

  #money-box { font-size: 22px; font-weight: 700; color: #4eff91; min-width: 110px; text-align: center; }
  #wanted-box { min-width: 130px; }
  #wanted-stars { font-size: 20px; letter-spacing: 2px; }
  #job-box { min-width: 150px; }
  #loc-box { min-width: 160px; }

  /* ── MINIMAP ── */
  #minimap-wrap {
    position: fixed; bottom: 12px; right: 12px; z-index: 60;
    border: 2px solid rgba(255,255,255,.25); border-radius: 8px; overflow: hidden;
  }
  #minimap { display: block; }

  /* ── NOTIFICATION ── */
  #notif {
    position: fixed; top: 70px; left: 50%; transform: translateX(-50%);
    background: rgba(0,0,0,.8); color: #fff; padding: 10px 22px;
    border-radius: 24px; font-size: 14px; z-index: 100;
    border: 1px solid rgba(255,255,255,.2); pointer-events: none;
    transition: opacity .4s; opacity: 0;
  }

  /* ── SCREENS (overlay panels) ── */
  .screen {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(0,0,0,.88); display: flex; align-items: center; justify-content: center;
    flex-direction: column; color: #fff;
  }
  .screen.hidden { display: none; }
  .panel {
    background: #1a1a2e; border: 1px solid #444; border-radius: 16px;
    padding: 28px 32px; max-width: 520px; width: 90%; max-height: 90vh; overflow-y: auto;
  }
  .panel h2 { font-size: 22px; margin-bottom: 18px; color: #4eff91; }
  .panel h3 { font-size: 15px; margin: 14px 0 8px; color: #ccc; }
  .btn {
    background: #4eff91; color: #000; border: none; border-radius: 8px;
    padding: 10px 20px; font-size: 14px; font-weight: 700; cursor: pointer;
    margin: 4px; transition: background .2s;
  }
  .btn:hover { background: #3dcc74; }
  .btn-red { background: #ff4e6a; color: #fff; }
  .btn-red:hover { background: #cc3050; }
  .btn-blue { background: #4e9eff; color: #fff; }
  .btn-blue:hover { background: #3070cc; }
  .btn-gold { background: #ffd700; color: #000; }
  .btn-gold:hover { background: #ccac00; }
  .btn-sm { padding: 6px 14px; font-size: 12px; }
  .close-btn { position: absolute; top: 12px; right: 16px; background: none; border: none; color: #aaa; font-size: 22px; cursor: pointer; }
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
  .option-card {
    background: #252540; border: 2px solid #333; border-radius: 10px;
    padding: 10px; cursor: pointer; text-align: center; transition: border-color .2s;
  }
  .option-card:hover, .option-card.selected { border-color: #4eff91; }
  .option-card .card-icon { font-size: 28px; margin-bottom: 6px; }
  .option-card .card-label { font-size: 12px; color: #ccc; }
  .color-swatch {
    width: 32px; height: 32px; border-radius: 50%; border: 3px solid #333;
    cursor: pointer; display: inline-block; margin: 3px; transition: border-color .2s;
  }
  .color-swatch.selected { border-color: #4eff91; }
  input[type=range] { width: 100%; accent-color: #4eff91; }
  label { font-size: 13px; color: #ccc; }
  select { background: #252540; color: #fff; border: 1px solid #444; border-radius: 6px; padding: 6px 10px; font-size: 13px; width: 100%; }

  /* ── TITLE SCREEN ── */
  #title-screen { background: radial-gradient(ellipse at center, #0d1b3e 0%, #000 80%); }
  #title-screen h1 {
    font-size: 52px; font-weight: 900;
    background: linear-gradient(135deg, #4eff91, #4e9eff, #ff4e91);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    text-shadow: none; margin-bottom: 6px;
  }
  #title-screen .sub { color: #888; font-size: 14px; margin-bottom: 30px; letter-spacing: 2px; }
  #title-screen .private-badge {
    background: #ff4e6a; color: #fff; font-size: 11px; font-weight: 700;
    padding: 3px 10px; border-radius: 20px; letter-spacing: 2px; margin-bottom: 24px;
  }

  /* ── CHAR CUSTOMIZER ── */
  #char-preview-wrap { display: flex; justify-content: center; margin-bottom: 16px; }
  #char-preview { width: 100px; height: 140px; }

  /* ── SHOP TABS ── */
  .tab-bar { display: flex; gap: 6px; margin-bottom: 14px; flex-wrap: wrap; }
  .tab { background: #252540; border: 1px solid #333; border-radius: 8px; padding: 7px 14px; cursor: pointer; font-size: 13px; color: #aaa; }
  .tab.active { background: #4eff91; color: #000; font-weight: 700; border-color: #4eff91; }

  /* ── INTERACTION PROMPT ── */
  #interact-prompt {
    position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%);
    background: rgba(0,0,0,.75); color: #fff; padding: 8px 20px;
    border-radius: 20px; font-size: 13px; z-index: 90;
    border: 1px solid rgba(255,255,255,.2); pointer-events: none;
    transition: opacity .3s; opacity: 0;
  }

  /* ── MONSTER MODE FLASH ── */
  #monster-flash {
    position: fixed; inset: 0; pointer-events: none; z-index: 40;
    background: radial-gradient(ellipse at center, transparent 40%, rgba(255,0,50,.3) 100%);
    opacity: 0; transition: opacity .5s;
  }

  /* Controls hint */
  #controls-hint {
    position: fixed; bottom: 12px; left: 12px; z-index: 60;
    background: rgba(0,0,0,.6); color: #888; font-size: 11px;
    padding: 8px 12px; border-radius: 8px; line-height: 1.7;
    border: 1px solid rgba(255,255,255,.1);
  }
</style>
</head>
<body>

<!-- ═══════════════════ TITLE SCREEN ═══════════════════ -->
<div id="title-screen" class="screen">
  <h1>Zaylin's World</h1>
  <div class="sub">OPEN-WORLD KID CITY</div>
  <div class="private-badge">🔒 PRIVATE TESTING</div>
  <button class="btn" style="font-size:18px;padding:14px 36px;" onclick="startGame()">PLAY NOW</button>
  <p style="color:#555;font-size:12px;margin-top:20px;">WASD/Arrows to move · E to interact · M for map · C for customizer</p>
</div>

<!-- ═══════════════════ CHARACTER CUSTOMIZER ═══════════════════ -->
<div id="char-screen" class="screen hidden">
  <div class="panel" style="position:relative;">
    <button class="close-btn" onclick="closeScreen('char-screen')">✕</button>
    <h2>👤 Character Customizer</h2>
    <div id="char-preview-wrap">
      <canvas id="char-preview" width="100" height="140"></canvas>
    </div>
    <h3>Skin Tone</h3>
    <div id="skin-swatches"></div>
    <h3>Hair Style</h3>
    <div id="hair-styles" class="grid-3"></div>
    <h3>Hair Color</h3>
    <div id="hair-colors"></div>
    <h3>Outfit</h3>
    <div id="outfit-styles" class="grid-2"></div>
    <h3>Outfit Color</h3>
    <div id="outfit-colors"></div>
    <h3>Accessories</h3>
    <div id="accessories" class="grid-3"></div>
    <h3>Name</h3>
    <input id="player-name-input" type="text" maxlength="16" value="Zaylin"
      style="width:100%;padding:8px 12px;background:#252540;color:#fff;border:1px solid #444;border-radius:8px;font-size:15px;">
    <br><br>
    <button class="btn btn-gold" onclick="saveCharacter()">✅ Save Look</button>
  </div>
</div>

<!-- ═══════════════════ SHOP ═══════════════════ -->
<div id="shop-screen" class="screen hidden">
  <div class="panel" style="position:relative;max-width:600px;">
    <button class="close-btn" onclick="closeScreen('shop-screen')">✕</button>
    <h2 id="shop-title">🛍️ Shop</h2>
    <div class="tab-bar" id="shop-tabs"></div>
    <div id="shop-content"></div>
  </div>
</div>

<!-- ═══════════════════ HOUSING ═══════════════════ -->
<div id="house-screen" class="screen hidden">
  <div class="panel" style="position:relative;">
    <button class="close-btn" onclick="closeScreen('house-screen')">✕</button>
    <h2>🏠 Housing</h2>
    <div id="house-content"></div>
  </div>
</div>

<!-- ═══════════════════ JOB ═══════════════════ -->
<div id="job-screen" class="screen hidden">
  <div class="panel" style="position:relative;">
    <button class="close-btn" onclick="closeScreen('job-screen')">✕</button>
    <h2>💼 Jobs</h2>
    <div id="job-content"></div>
  </div>
</div>

<!-- ═══════════════════ SCHOOL ═══════════════════ -->
<div id="school-screen" class="screen hidden">
  <div class="panel" style="position:relative;">
    <button class="close-btn" onclick="closeScreen('school-screen')">✕</button>
    <h2>🎓 School & Stats</h2>
    <div id="school-content"></div>
  </div>
</div>

<!-- ═══════════════════ NPC DIALOG ═══════════════════ -->
<div id="npc-screen" class="screen hidden">
  <div class="panel" style="position:relative;max-width:420px;">
    <button class="close-btn" onclick="closeScreen('npc-screen')">✕</button>
    <h2 id="npc-name-title">NPC</h2>
    <p id="npc-dialog-text" style="color:#ccc;line-height:1.6;margin-bottom:16px;"></p>
    <div id="npc-options"></div>
  </div>
</div>

<!-- ═══════════════════ MINIMAP ═══════════════════ -->
<div id="minimap-wrap"><canvas id="minimap" width="160" height="160"></canvas></div>

<!-- ═══════════════════ HUD ═══════════════════ -->
<div id="hud">
  <div class="hud-box" id="stat-bars">
    <h3>Stats</h3>
    <div class="sbar"><span style="width:50px">❤️ HP</span><div class="sbar-track"><div class="sbar-fill" id="bar-hp" style="width:100%;background:#ff4e6a"></div></div></div>
    <div class="sbar"><span style="width:50px">⚡ Energy</span><div class="sbar-track"><div class="sbar-fill" id="bar-energy" style="width:80%;background:#4e9eff"></div></div></div>
    <div class="sbar"><span style="width:50px">😊 Mood</span><div class="sbar-track"><div class="sbar-fill" id="bar-mood" style="width:75%;background:#ffd700"></div></div></div>
    <div class="sbar"><span style="width:50px">📚 Edu</span><div class="sbar-track"><div class="sbar-fill" id="bar-edu" style="width:20%;background:#a64eff"></div></div></div>
    <div class="sbar"><span style="width:50px">💪 Str</span><div class="sbar-track"><div class="sbar-fill" id="bar-str" style="width:10%;background:#ff914e"></div></div></div>
  </div>
  <div class="hud-box" id="money-box">
    <h3>💰 Cash</h3>
    <span id="money-display">$250</span>
  </div>
  <div class="hud-box" id="wanted-box">
    <h3>⭐ Wanted</h3>
    <div id="wanted-stars">☆☆☆☆☆</div>
    <div id="monster-badge" style="display:none;color:#ff4e6a;font-weight:700;font-size:12px;margin-top:4px;">👹 MONSTER MODE</div>
  </div>
  <div class="hud-box" id="job-box">
    <h3>💼 Job</h3>
    <div id="hud-job">Unemployed</div>
    <div id="hud-shift" style="font-size:11px;color:#888;margin-top:2px;"></div>
  </div>
  <div class="hud-box" id="loc-box">
    <h3>📍 Location</h3>
    <div id="hud-location">Zaylin City</div>
    <div style="font-size:11px;color:#888;margin-top:2px;" id="hud-time"></div>
  </div>
</div>

<!-- ═══════════════════ NOTIFICATIONS ═══════════════════ -->
<div id="notif"></div>
<div id="interact-prompt"></div>
<div id="monster-flash"></div>

<!-- ═══════════════════ CONTROLS HINT ═══════════════════ -->
<div id="controls-hint">
  WASD/↑↓←→ Move &nbsp;·&nbsp; E Interact<br>
  F Enter/Exit Car &nbsp;·&nbsp; M Monster Mode<br>
  C Customize &nbsp;·&nbsp; J Jobs &nbsp;·&nbsp; H Housing<br>
  Esc Menu
</div>

<!-- ═══════════════════ GAME CANVAS ═══════════════════ -->
<canvas id="gameCanvas"></canvas>

<script>
// ═══════════════════════════════════════════════════════════
//  ZAYLIN'S WORLD  —  Pure HTML5 Canvas Game Engine
//  No external dependencies. Private testing build.
// ═══════════════════════════════════════════════════════════

const canvas = document.getElementById('gameCanvas');
const ctx    = canvas.getContext('2d');
const mm     = document.getElementById('minimap');
const mmCtx  = mm.getContext('2d');

// ── Resize ──
function resize() {
  canvas.width  = window.innerWidth;
  canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

// ─────────────────────────────────────────────────────────
//  GAME STATE
// ─────────────────────────────────────────────────────────
const STATE = {
  running: false,
  inCar: false,
  monsterMode: false,
  gameTime: 8 * 60,        // minutes since midnight
  day: 1,
  wantedLevel: 0,
  wantedTimer: 0,
};

const PLAYER = {
  x: 1200, y: 1200,
  w: 22, h: 30,
  speed: 2.8,
  dx: 0, dy: 0,
  facing: 'down',
  name: 'Zaylin',
  // stats 0-100
  hp: 100, energy: 80, mood: 75, education: 20, strength: 10,
  // inventory & money
  money: 250,
  job: null,
  shiftActive: false,
  shiftProgress: 0,
  house: null,
  // customization
  skinTone: '#C68642',
  hairStyle: 0,
  hairColor: '#2b1d0e',
  outfitStyle: 0,
  outfitColor: '#4e9eff',
  accessory: 0,
  // jewelry (Frostbox)
  jewelry: { necklace: null, rings: [], earrings: null },
  // Block Supply gear
  gear: { backpack: null, cap: null, shoes: null },
  // NPC memory: npcId -> { attitude, lastTopic, visits }
  npcMemory: {},
};

const CAM = { x: 0, y: 0 };
const KEYS = {};
let activeCar = null;

// ─────────────────────────────────────────────────────────
//  WORLD MAP  (tile-based, 80×80 tiles, 32px each)
// ─────────────────────────────────────────────────────────
const TILE = 32;
const MAP_W = 100, MAP_H = 100;
// Tile types
const T = { GRASS:0, ROAD:1, SIDEWALK:2, BUILDING:3, PARK:4,
            WATER:5, BEACH:6, PARKING:7, SCHOOL:8, SHOP:9,
            HOUSE:10, POLICE:11, HOSPITAL:12, GAS:13, BANK:14 };

const TILE_COLORS = {
  0:'#3a7d44', 1:'#555', 2:'#aaa', 3:'#444', 4:'#4a9e5c',
  5:'#1a6eaf', 6:'#d4b483', 7:'#666', 8:'#3d6bb5', 9:'#c04040',
  10:'#8b5e3c', 11:'#2255cc', 12:'#cc4444', 13:'#cc8822', 14:'#ccaa22'
};

// Generate map procedurally
const MAP = new Uint8Array(MAP_W * MAP_H);
(function buildMap(){
  // Fill grass
  MAP.fill(T.GRASS);
  // Main roads (grid)
  for(let x=0;x<MAP_W;x++){
    for(let y=0;y<MAP_H;y++){
      // horizontal roads every 12
      if(y%12===6||y%12===7) setTile(x,y,T.ROAD);
      // vertical roads every 12
      if(x%12===6||x%12===7) setTile(x,y,T.ROAD);
    }
  }
  // Sidewalks beside roads
  for(let x=0;x<MAP_W;x++){
    for(let y=0;y<MAP_H;y++){
      if(getTile(x,y)===T.GRASS){
        if(isNearRoad(x,y)) setTile(x,y,T.SIDEWALK);
      }
    }
  }
  // Place blocks of buildings
  for(let bx=0;bx<MAP_W;bx+=12){
    for(let by=0;by<MAP_H;by+=12){
      placeCityBlock(bx, by);
    }
  }
  // Water/beach in corner
  for(let x=0;x<18;x++) for(let y=80;y<MAP_H;y++) setTile(x,y,T.WATER);
  for(let x=0;x<22;x++) for(let y=78;y<82;y++) setTile(x,y,T.BEACH);
  // Park
  for(let x=14;x<26;x++) for(let y=14;y<24;y++) if(getTile(x,y)!==T.ROAD) setTile(x,y,T.PARK);
})();

function setTile(x,y,t){ if(x>=0&&x<MAP_W&&y>=0&&y<MAP_H) MAP[y*MAP_W+x]=t; }
function getTile(x,y){ if(x<0||x>=MAP_W||y<0||y>=MAP_H) return T.BUILDING; return MAP[y*MAP_W+x]; }
function isNearRoad(x,y){
  for(let dx=-1;dx<=1;dx++) for(let dy=-1;dy<=1;dy++){
    if(getTile(x+dx,y+dy)===T.ROAD) return true;
  }
  return false;
}
function placeCityBlock(bx,by){
  const types = [T.BUILDING,T.SHOP,T.HOUSE,T.SCHOOL,T.POLICE,T.HOSPITAL,T.GAS,T.BANK,T.PARKING];
  const pick = (x,y) => {
    let hash = (x*73856093 ^ y*19349663) >>> 0;
    return types[hash % types.length];
  };
  for(let x=bx+1;x<bx+5&&x<MAP_W;x++){
    for(let y=by+1;y<by+5&&y<MAP_H;y++){
      if(getTile(x,y)===T.GRASS||getTile(x,y)===T.SIDEWALK){
        setTile(x,y, pick(x,y));
      }
    }
  }
}

// ─────────────────────────────────────────────────────────
//  BUILDINGS / ZONES (named locations)
// ─────────────────────────────────────────────────────────
const ZONES = [
  { name:'Zaylin City Center', x:18*TILE, y:18*TILE, r:200, color:'#4e9eff' },
  { name:'Frostbox Jewelry',   x:37*TILE, y:8*TILE,  r:80, color:'#a64eff' },
  { name:'Block Supply HQ',    x:60*TILE, y:10*TILE, r:80, color:'#ff914e' },
  { name:'Zaylin High School', x:15*TILE, y:40*TILE, r:90, color:'#ffd700' },
  { name:'City Hospital',      x:70*TILE, y:40*TILE, r:80, color:'#ff4e6a' },
  { name:'Police HQ',          x:50*TILE, y:50*TILE, r:80, color:'#4e9eff' },
  { name:'Beach District',     x:8*TILE,  y:85*TILE, r:100, color:'#d4b483' },
  { name:'Zaylin Heights',     x:80*TILE, y:20*TILE, r:90, color:'#3a7d44' },
  { name:'Car Dealership',     x:30*TILE, y:60*TILE, r:80, color:'#ff4e6a' },
  { name:'City Bank',          x:45*TILE, y:25*TILE, r:70, color:'#ccaa22' },
  { name:'Zaylin Park',        x:20*TILE, y:18*TILE, r:120, color:'#4a9e5c' },
];

function getZone(wx,wy){
  for(const z of ZONES){
    const dx=wx-z.x, dy=wy-z.y;
    if(dx*dx+dy*dy < z.r*z.r) return z;
  }
  return null;
}

// ─────────────────────────────────────────────────────────
//  CARS
// ─────────────────────────────────────────────────────────
const CAR_COLORS = ['#ff4e4e','#4e9eff','#4eff91','#ffd700','#ff914e','#a64eff','#fff','#333'];
const CAR_NAMES  = ['Viper GT','Cruiser X','Neon Run','Shadow','Blitz Z','Phantom','Classic','Storm'];

class Car {
  constructor(x,y,color,name,isNPC=true){
    this.x=x; this.y=y; this.w=28; this.h=48;
    this.angle=0; this.speed=0; this.maxSpeed=isNPC?2.5:5;
    this.color=color; this.name=name;
    this.isNPC=isNPC; this.occupied=false;
    this.aiTarget=null; this.aiTimer=0;
  }
  getBounds(){
    return { x:this.x-this.w/2, y:this.y-this.h/2, w:this.w, h:this.h };
  }
}

// Player car pool
const playerCars = [
  new Car(1250, 1180, '#ff4e4e', 'Viper GT', false),
  new Car(1310, 1180, '#4e9eff', 'Cruiser X', false),
];
playerCars.forEach(c=>c.isNPC=false);

// NPC cars
const npcCars = [];
for(let i=0;i<30;i++){
  const cx = 200 + Math.random()*2800;
  const cy = 200 + Math.random()*2800;
  npcCars.push(new Car(cx, cy, CAR_COLORS[i%CAR_COLORS.length], CAR_NAMES[i%CAR_NAMES.length], true));
}
const allCars = [...playerCars, ...npcCars];

// ─────────────────────────────────────────────────────────
//  NPCs
// ─────────────────────────────────────────────────────────
const NPC_NAMES = ['Maya','Jordan','Tyler','Alex','Sam','Riley','Quinn','Morgan','Casey','Avery',
                   'Officer Chen','Nurse Blake','Principal Hart','Mr. Frost','Coach Davis'];
const NPC_ROLES = ['Friend','Rival','Shopkeeper','Police','Nurse','Teacher','Jeweler','Coach','Neighbor','Classmate',
                   'Officer','Nurse','Principal','Jeweler','Coach'];
const NPC_SKIN  = ['#C68642','#8D5524','#F1C27D','#FFDBB4','#3b2314','#D2956A'];

class NPC {
  constructor(id, x, y, name, role){
    this.id=id; this.x=x; this.y=y; this.w=20; this.h=28;
    this.name=name; this.role=role;
    this.skin=NPC_SKIN[id%NPC_SKIN.length];
    this.color=CAR_COLORS[id%CAR_COLORS.length];
    this.dx=0; this.dy=0;
    this.walkTimer=0; this.walkDuration=0;
    this.facing='down';
  }
}

